generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum MembershipStatus {
  ACTIVE
  EXPIRED
  FROZEN
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum SaleType {
  PRODUCT
  DAY_PASS
}

// --- MODELS ---
model User {
  id        Int       @id @default(autoincrement())
  roleId    Int
  dni       String?   @unique
  email     String?   @unique
  password  String?
  fullName  String
  phone     String?
  photoUrl  String?
  qrCode    String?   @unique // Para el torniquete
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  role          Role           @relation(fields: [roleId], references: [id])
  memberships   Membership[]
  cashRegisters CashRegister[]
  attendances   Attendance[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       User[]
  permissions Permission[] // Relación implícita M-N de Prisma
}

model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  roles       Role[] // Relación implícita M-N de Prisma
}

model Plan {
  id           Int       @id @default(autoincrement())
  name         String
  durationDays Int
  price        Decimal   @db.Decimal(10, 2)
  allowsFreeze Boolean   @default(false)
  description  String?
  deletedAt    DateTime?

  memberships Membership[]
}

model Shift {
  id        Int       @id @default(autoincrement())
  name      String
  startTime DateTime  @db.Time
  endTime   DateTime  @db.Time
  deletedAt DateTime?

  memberships Membership[]
}

model Membership {
  id             Int              @id @default(autoincrement())
  userId         Int
  planId         Int
  shiftId        Int
  startDate      DateTime         @db.Date
  endDate        DateTime         @db.Date
  status         MembershipStatus @default(ACTIVE)
  totalPrice     Decimal          @db.Decimal(10, 2)
  pendingBalance Decimal          @default(0) @db.Decimal(10, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  plan     Plan      @relation(fields: [planId], references: [id])
  shift    Shift     @relation(fields: [shiftId], references: [id])
  freezes  Freeze[]
  payments Payment[]
}

model Freeze {
  id           Int      @id @default(autoincrement())
  membershipId Int
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  reason       String?

  membership Membership @relation(fields: [membershipId], references: [id])
}

model Payment {
  id             Int      @id @default(autoincrement())
  membershipId   Int
  cashRegisterId Int
  amount         Decimal  @db.Decimal(10, 2)
  paymentMethod  String
  date           DateTime @default(now())
  notes          String?

  membership   Membership   @relation(fields: [membershipId], references: [id])
  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])
}

model CashRegister {
  id                Int                @id @default(autoincrement())
  userId            Int // El empleado que abre la caja
  openingAmount     Decimal            @db.Decimal(10, 2)
  openingDate       DateTime           @default(now())
  closingAmountSys  Decimal?           @db.Decimal(10, 2)
  closingAmountReal Decimal?           @db.Decimal(10, 2)
  closingDate       DateTime?
  status            CashRegisterStatus @default(OPEN)

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]
  sales    Sale[]
}

model Sale {
  id             Int      @id @default(autoincrement())
  cashRegisterId Int
  type           SaleType
  total          Decimal  @db.Decimal(10, 2)
  paymentMethod  String
  date           DateTime @default(now())

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])
  details      SaleDetail[]
  dayPasses    DayPass[]
}

model SaleDetail {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Product {
  id        Int       @id @default(autoincrement())
  name      String
  category  String?
  price     Decimal   @db.Decimal(10, 2)
  barcode   String?   @unique
  stock     Int       @default(0)
  deletedAt DateTime?

  saleDetails SaleDetail[]
}

model DayPass {
  id        Int      @id @default(autoincrement())
  saleId    Int
  code      String   @unique // Código QR efímero
  buyerName String
  dni       String?
  validDate DateTime @db.Date
  isUsed    Boolean  @default(false)

  sale        Sale         @relation(fields: [saleId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id           Int      @id @default(autoincrement())
  userId       Int? // Nulo si es visitante
  dayPassId    Int? // Nulo si es socio
  timestamp    DateTime @default(now())
  isAllowed    Boolean
  denialReason String?

  user    User?    @relation(fields: [userId], references: [id])
  dayPass DayPass? @relation(fields: [dayPassId], references: [id])
}
